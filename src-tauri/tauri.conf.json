{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/packages/tauri-cli/schema.json",
  "productName": "RezeClaw",
  "identifier": "com.rezeclaw.desktop",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "widget",
        "title": "RezeClaw",
        "width": 480,
        "height": 320,
        "minWidth": 400,
        "minHeight": 280,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "alwaysOnTop": false
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
